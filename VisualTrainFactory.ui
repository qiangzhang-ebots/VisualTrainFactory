<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1250</width>
    <height>847</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>YOLO + HRNet 全流程训练平台</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #0b1020;
    color: #e8eef9;
    font-family: &quot;Microsoft YaHei UI&quot;;
    font-size: 10pt;
}

QWidget#centralwidget {
    background-color: #0b1020;
}

QFrame#frameHeader {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #101a34, stop:1 #152447);
    border: 1px solid #27355c;
    border-radius: 14px;
}

QLabel {
    color: #e8eef9;
}

QCheckBox {
    color: #ffffff;
}

QLabel#labelTitle {
    color: #f7fbff;
    letter-spacing: 1px;
}

QPushButton {
    background-color: #1b2947;
    color: #edf4ff;
    border: 1px solid #30466f;
    border-radius: 10px;
    padding: 8px 14px;
    min-height: 18px;
}

QPushButton:hover {
    background-color: #24365c;
    border-color: #4d72b5;
}

QPushButton:pressed {
    background-color: #17243d;
}

QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox, QTextBrowser, QListWidget, QTreeWidget, QGraphicsView {
    background-color: #111a2f;
    color: #eef4ff;
    border: 1px solid #2e4064;
    border-radius: 8px;
    selection-background-color: #4da3ff;
    selection-color: #ffffff;
}

QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox {
    min-height: 28px;
    padding: 4px 8px;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background-color: #111a2f;
    color: #eef4ff;
    selection-background-color: #355fa3;
    border: 1px solid #2e4064;
}

QGroupBox {
    color: #f2f6ff;
    background-color: rgba(16, 26, 48, 0.92);
    border: 1px solid #31486f;
    border-radius: 14px;
    margin-top: 18px;
    padding-top: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 14px;
    padding: 0 8px;
    color: #89c2ff;
}

QTabWidget::pane {
    border: 1px solid #31486f;
    border-radius: 12px;
    top: -1px;
    background-color: #0f1729;
}

QTabBar::tab {
    background: #17233d;
    color: #bfd0ea;
    border: 1px solid #31486f;
    border-bottom: none;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    padding: 8px 14px;
    margin-right: 4px;
    min-width: 84px;
}

QTabBar::tab:selected {
    background: #24365c;
    color: #ffffff;
    border-color: #4d72b5;
}

QTabBar::tab:hover {
    background: #1f2e52;
}

QSplitter::handle {
    background-color: #30466f;
}

QTextBrowser, QListWidget, QTreeWidget {
    alternate-background-color: #0f1729;
}

QHeaderView::section {
    background-color: #16233f;
    color: #e9f0fb;
    padding: 6px 8px;
    border: none;
    border-bottom: 1px solid #31486f;
}

QScrollBar:vertical {
    background: #0f1729;
    width: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #355fa3;
    min-height: 24px;
    border-radius: 6px;
}

QScrollBar::handle:vertical:hover {
    background: #4d72b5;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
    border: none;
}

QFrame#labelMapContainer {
    background-color: rgba(13, 20, 38, 0.96);
    border: 1px solid #31486f;
    border-radius: 12px;
    padding: 8px;
}

QFrame#labelMapContainer QLabel {
    color: #f2f6ff;
}

QFrame#labelMapContainer QScrollArea {
    background: transparent;
    border: none;
}

QFrame#labelMapContainer QScrollArea &gt; QWidget &gt; QWidget {
    background: transparent;
}

QStatusBar {
    background-color: #0b1020;
    color: #9eb5d8;
}
</string>
